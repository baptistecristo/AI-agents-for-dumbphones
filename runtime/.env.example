# --- API Next.js (skills & prompts) ---
NEXT_API_URL=http://localhost:3000
RUNTIME_API_SECRET=            # le même que côté web/.env.local

# --- Ce serveur (websockets média) ---
PUBLIC_HOST=exemple.ngrok.app  # hôte public SANS schéma (wss:// est ajouté)

# --- Téléphonie (l'incompressible : il faut un opérateur) ---
TELEPHONY_PROVIDER=twilio      # twilio | telnyx
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=            # numéro appelant pour les missions sortantes
TELNYX_API_KEY=

# --- STT local (faster-whisper) ---
WHISPER_MODEL=medium           # small = plus rapide, medium = meilleur FR
WHISPER_DEVICE=auto            # cpu | cuda | auto

# --- TTS (Piper, une voix par langue, serveur séparé à lancer soi-même, voir README) ---
# RACINE du serveur Piper, jamais une route : /voices ET la route de synthèse
# s'en déduisent.
PIPER_BASE_URL=http://localhost:5000
# Route de synthèse. Elle a changé : POST /synthesize à partir de piper-tts
# 1.5.0, POST / de 1.3 à 1.4.2. "auto" (défaut) la détecte au démarrage et
# couvre les deux ; épingler /synthesize ou / si un proxy gêne la détection.
PIPER_SYNTHESIZE_PATH=auto
# La langue de la session ("fr" | "en" | "es", renvoyée par /api/runtime/session) choisit la voix.
PIPER_VOICE_FR=fr_FR-siwis-medium # alternatives : fr_FR-upmc-medium, fr_FR-tom-medium
PIPER_VOICE_EN=en_US-lessac-medium # alternatives : en_US-amy-medium, en_GB-alba-medium
PIPER_VOICE_ES=es_ES-davefx-medium # alternative : es_ES-sharvard-medium
# PIPER_VOICE=                   # (déprécié) ancienne variable ; si définie, sert de voix FR

# --- Cerveau ---
LLM_PROVIDER=ollama            # ollama (100% local) | mistral (API EU) | anthropic
OLLAMA_MODEL=qwen2.5:7b        # bon tool-calling FR ; sinon mistral-nemo, llama3.1:8b
OLLAMA_URL=http://localhost:11434/v1
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
