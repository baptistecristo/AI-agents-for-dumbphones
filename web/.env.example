# ------------------------------------------------------------------
# Copier vers .env.local (dev) / variables Vercel (prod). Tout en UTF-8.
# ------------------------------------------------------------------

# URL publique de l'app (pas de slash final). En dev avec webhooks : URL ngrok.
APP_URL=http://localhost:3000

# Marque / nom de l'agent vocal (changer les deux ensemble)
NEXT_PUBLIC_BRAND_NAME=Agent
AGENT_NAME=Agent

# --- Supabase (créer le projet en région EU : eu-west / eu-central) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # secret serveur, jamais côté client

# --- Connexion au site : boutons OAuth affichés sur /connexion ---
# Liste séparée par des virgules. Chaque fournisseur doit d'abord être activé
# dans Supabase (Authentication > Providers). Non défini : les quatre s'affichent.
# Le lien magique et le code e-mail à 6 chiffres restent toujours dispo. Config
# côté Supabase (URL, gabarit e-mail, fournisseurs) : voir docs/auth.md.
#   valeurs : google, apple, microsoft (= azure/outlook), github
NEXT_PUBLIC_AUTH_PROVIDERS=google,apple,microsoft,github

# --- Chiffrement applicatif des tokens OAuth (32 octets base64) ---
# Générer :  openssl rand -base64 32
ENCRYPTION_KEY=

# --- Runtime vocal ---
# selfhost = runtime/ auto-hébergé (Pipecat, par défaut) · vapi = plateforme managée
RUNTIME=selfhost
RUNTIME_URL=http://localhost:8000     # URL du serveur runtime/ (self-host)
RUNTIME_API_SECRET=                   # secret partagé web <-> runtime (openssl rand -hex 24)

# --- Vapi (optionnel, seulement si RUNTIME=vapi) ---
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=          # = le Token de la credential Vapi « Bearer Token »
                              # (dashboard > Integrations > Server Configuration ;
                              #  Header Name: X-Vapi-Secret, préfixe Bearer décoché)
VAPI_WEBHOOK_CREDENTIAL_ID=   # l'ID de cette même credential. SANS LUI, Vapi appelle
                              # le webhook sans le header : 401 en prod, aucun appel
                              # ni tool-call n'aboutit. À définir avant setup-vapi.
VAPI_ASSISTANT_ID=            # rempli après le 1er POST /api/admin/setup-vapi
VAPI_PHONE_NUMBER_ID=         # ← À REMPLIR QUAND LE NUMÉRO SERA ACHETÉ, puis relancer setup-vapi

# --- Limite de débit sur le numéro entrant (web/src/lib/rate-limit.ts) ---
# Le numéro est public : une minute de voix coûte ~0,14 $. maxDurationSeconds
# borne un appel (~0,42 $) ; ceci borne le nombre d'appels. Les appelants sans
# numéro présenté partagent un seul compteur. Valeurs par défaut ci-dessous.
INBOUND_MAX_CALLS_PER_CALLER_HOUR=5
INBOUND_MAX_CALLS_PER_CALLER_DAY=20
INBOUND_MAX_CALLS_PER_DAY=60           # plafond global. 60 appels : ~5 $/jour en usage
                                       # normal (~40 s/appel), ~25 $ si tous vont au cap
                                       # de 180 s. À remonter en connaissance de cause.

# Modèles (cerveau de l'agent) — deux niveaux, §3 du doc d'archi
AGENT_MODEL_PROVIDER=anthropic
AGENT_MODEL=claude-haiku-4-5-20251001   # tours ordinaires (rapide, pas cher)
OUTBOUND_MODEL=claude-sonnet-5          # missions sortantes (raisonnement)

# Voix ElevenLabs (FR/EN naturel). Débit codé en dur à 1.0 (vitesse normale).
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# --- Twilio (SMS + vérification OTP ; le numéro FR exige un bundle réglementaire) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=           # numéro SMS (peut être le même que le numéro vocal)
TWILIO_VERIFY_SERVICE_SID=    # console Twilio > Verify > Services > créer

# --- Google OAuth (console.cloud.google.com > créer un client OAuth web) ---
# Redirect URI à déclarer : {APP_URL}/api/oauth/google/callback
# Scopes : calendar.events, contacts.readonly, userinfo.email ("sensitive" ->
# vérification Google nécessaire pour sortir du cap 100 utilisateurs test)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Itinéraires (openrouteservice.org — gratuit jusqu'à 2000 req/jour) ---
ORS_API_KEY=

# --- Protection des crons et de la route admin ---
# Générer :  openssl rand -hex 24
# L'ordonnancement vit dans Postgres (migration 0004), pas chez l'hébergeur :
# reporter CETTE valeur dans le Vault Supabase, sinon les crons reçoivent un 401.
#   select vault.create_secret('<cette valeur>', 'cron_secret');
#   select vault.create_secret('<APP_URL>', 'app_url');
CRON_SECRET=

# --- Rapports de capacités manquantes (digest e-mail quotidien via Resend) ---
# RESEND_API_KEY est fourni automatiquement par l'intégration Vercel × Resend.
RESEND_API_KEY=
# Expéditeur vérifié Resend (onboarding@resend.dev au départ, ou ton domaine).
REPORT_EMAIL_FROM=
# Destinataire du digest quotidien. SECRET : ne jamais committer de vraie valeur.
REPORT_EMAIL_TO=
