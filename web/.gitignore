# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...sauf le gabarit : sans lui, un clone du repo n'a aucune liste des
# variables à renseigner. Il ne contient que des placeholders, jamais de secret.
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
